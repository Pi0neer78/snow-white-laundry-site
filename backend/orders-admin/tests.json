{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Получение списка заявок",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"orders": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Проверка пароля неверная",
      "method": "POST",
      "path": "/",
      "body": {"password": "wrong-password-123"},
      "expectedStatus": 401
    },
    {
      "name": "Смена статуса без id",
      "method": "PUT",
      "path": "/",
      "body": {"status": "done"},
      "expectedStatus": 400
    },
    {
      "name": "Удаление без id",
      "method": "DELETE",
      "path": "/",
      "expectedStatus": 400
    }
  ]
}